---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { getPageCopy, getPageData } from '../content/queries';

import indexHero from '../assets/index-hero.jpg';

const copy = await getPageCopy('product-development');
const data = await getPageData('productDevelopmentData', 'product-development');
---

<Layout title={copy.data.layoutTitle} description={copy.data.layoutDescription}>
  <section class="home-hero">
    <div class="home-shell">
      <nav class="breadcrumb reveal-up" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">&gt;</span>
        <span class="text-emerald-400 opacity-80">Product Development</span>
      </nav>

      <div class="hero-grid mb-16">
        <div class="hero-copy reveal-up" style="transition-delay: 100ms;">
          <p class="hero-eyebrow">{copy.data.heroEyebrow}</p>
          <h1>{copy.data.heroTitle}</h1>
          <p class="hero-lead">{copy.data.heroLead}</p>
        </div>

        <aside class="hero-media-frame reveal-scale" style="transition-delay: 200ms;" aria-label="Product Development">
          <Image
            src={indexHero}
            alt="BioChroma Labs scientists reviewing product development data"
            loading="eager"
            class="h-full w-full rounded-2xl object-cover"
          />
          <div class="hero-media-caption">
            <p>{copy.data.heroMediaTitle}</p>
            <span>{copy.data.heroMediaText}</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {copy.Content && (
    <section class="home-section border-t border-white/5 bg-slate-900/20">
      <div class="home-shell">
        <div class="prose prose-invert prose-emerald mx-auto max-w-4xl text-center text-lg leading-relaxed text-slate-300 reveal-up">
          <copy.Content />
        </div>
      </div>
    </section>
  )}

  <section class="home-section border-t border-white/5">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.data.overviewTitle}</p>
        <h2>{copy.data.overviewLead}</h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.supportAreas.map((item, index) => (
          <article class="rounded-xl border border-white/10 bg-white/5 p-6 reveal-up" style={`transition-delay: ${index * 80}ms;`}>
            <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
              <i class={`${item.icon} text-xl`}></i>
            </span>
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/40">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.data.areasTitle}</p>
        <h2>{copy.data.areasLead}</h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.engagementModes.map((mode, index) => (
          <article class="rounded-xl border border-white/10 bg-white/5 p-6 reveal-up" style={`transition-delay: ${index * 100}ms;`}>
            <h3 class="text-base font-semibold text-white">{mode.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{mode.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5">
    <div class="home-shell max-w-4xl">
      <div class="section-heading reveal-up">
        <p>{copy.data.fitTitle}</p>
        <h2>{copy.data.fitLead}</h2>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {data.lifecycleStages.map((stage, index) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200 reveal-scale" style={`transition-delay: ${index * 70}ms;`}>
            {stage}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/50">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.data.actionsTitle}</p>
        <h2>{copy.data.actionsLead}</h2>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
        {data.actionCards.map((action, index) => (
          <a href={action.href} class="rounded-xl border border-white/10 bg-white/5 p-6 transition-colors hover:border-emerald-400/30 hover:bg-emerald-500/5 reveal-up" style={`transition-delay: ${index * 100}ms;`}>
            <h3 class="text-lg font-semibold text-white">{action.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{action.description}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-emerald-300">
              {action.label}
              <i class="ri-arrow-right-up-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5">
    <div class="home-shell reveal-up">
      <CTA
        title={copy.data.ctaTitle}
        description={copy.data.ctaDescription}
        primaryLabel={copy.data.ctaPrimaryLabel}
        primaryHref={copy.data.ctaPrimaryHref}
        secondaryLabel={copy.data.ctaSecondaryLabel}
        secondaryHref={copy.data.ctaSecondaryHref}
      />
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { font-size: 0.875rem; margin-bottom: 2rem; display: flex; gap: 0.5rem; }
  .breadcrumb a { color: rgba(255, 255, 255, 0.6); text-decoration: none; transition: 0.2s; }
  .breadcrumb a:hover { color: var(--color-primary); }
</style>
