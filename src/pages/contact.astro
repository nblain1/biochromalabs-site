---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import ProcessStrip from '../components/sections/ProcessStrip.astro';
import UtilitySidecard from '../components/sections/UtilitySidecard.astro';
import ActionBand from '../components/sections/ActionBand.astro';
import { getPageContent, getSiteData } from '../content/queries';
import contactHero from '../assets/contact-hero.jpg';

const { copy, data, Content } = await getPageContent('contact');
const site = await getSiteData();
---

<Layout
  title={copy.layoutTitle}
  description={copy.layoutDescription}
>
  <section class="home-hero">
    <div class="home-shell">
      <nav class="breadcrumb reveal-up" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">&gt;</span>
        <span class="text-emerald-400 opacity-80">Contact</span>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy reveal-up" style="transition-delay: 100ms;">
          <p class="hero-eyebrow">{copy.heroEyebrow}</p>
          <h1>{copy.heroTitle}</h1>
          <p class="hero-lead">{copy.heroLead}</p>
        </div>

        <aside class="hero-media-frame reveal-scale" style="transition-delay: 200ms;" aria-label="Client Support">
          <Image
            src={contactHero}
            alt="BioChroma Client Consultation"
            loading="eager"
            class="w-full h-full object-cover rounded-2xl"
          />
          <div class="hero-media-caption">
            <p>{copy.heroMediaTitle}</p>
            <span>{copy.heroMediaText}</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {Content && (
    <section class="home-section border-t border-white/5 bg-slate-900/20">
      <div class="home-shell">
        <div class="prose prose-invert prose-emerald max-w-4xl mx-auto text-center text-lg leading-relaxed text-slate-300 reveal-up">
          <Content />
        </div>
      </div>
    </section>
  )}

  <section class="home-section border-t border-white/5">
    <div class="home-shell">
      <div class="mb-16 reveal-up">
        <SectionHeading title={copy.routingTitle} compact className="mb-6" />
        <ProcessStrip steps={data.routingSteps} compact />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        <div class="lg:col-span-2 reveal-up">
          <SectionHeading title={copy.directoryTitle} compact className="mb-8" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {data.pathways.map((path, index) => (
              <article
                class="group p-6 bg-white/5 border border-white/10 rounded-xl hover:border-emerald-400/30 hover:bg-white/10 transition-all duration-300 reveal-up"
                style={`transition-delay: ${(index * 60) + 120}ms;`}
              >
                <h3 class="text-white text-lg font-bold mb-2 group-hover:text-emerald-400 transition-colors">{path.title}</h3>
                <p class="text-slate-300 text-sm leading-relaxed mb-4">{path.description}</p>
                <div class="flex flex-wrap gap-3">
                  <a href={`mailto:${path.email}`} class="inline-flex items-center gap-2 text-emerald-400 text-sm font-semibold">
                    <i class="ri-mail-line"></i>{path.email}
                  </a>
                  <a href={path.serviceHref} class="inline-flex items-center gap-2 text-slate-200 text-sm font-semibold hover:text-white transition-colors">
                    <i class="ri-arrow-right-up-line"></i>{path.serviceLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="reveal-up" style="transition-delay: 300ms;">
          <UtilitySidecard
            title={copy.headquartersTitle}
            items={[
              {
                icon: 'ri-map-pin-line',
                label: 'Address',
                text: data.headquarters.addressLines.join(', '),
                href: data.headquarters.mapUrl,
                target: '_blank'
              },
              {
                icon: 'ri-phone-line',
                label: 'Main office',
                text: site.phone,
                href: `tel:${site.phone.replace(/[^\d+]/g, '')}`
              }
            ]}
            note={data.headquarters.responseNote}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/20">
    <div class="home-shell">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <ActionBand
          title={copy.sampleResourcesTitle}
          actions={data.sampleResources.map((resource) => ({
            label: resource.title,
            detail: resource.description,
            href: resource.href,
            icon: resource.href.endsWith('.pdf') ? 'ri-download-line' : 'ri-mail-line'
          }))}
          className="reveal-up"
        />

        <ActionBand
          title={data.existingClients.title}
          description={data.existingClients.description}
          actions={data.existingClients.actions.map((action) => ({
            ...action,
            icon: action.href.startsWith('tel:') ? 'ri-phone-line' : 'ri-mail-line'
          }))}
          compact
          className="reveal-up"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { font-size: 0.875rem; margin-bottom: 2rem; display: flex; gap: 0.5rem; }
  .breadcrumb a { color: rgba(255, 255, 255, 0.6); text-decoration: none; transition: 0.2s; }
  .breadcrumb a:hover { color: var(--color-primary); }
</style>
