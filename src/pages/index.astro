---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { pageCopy, pageData, site } from '../data/content';

import indexHero from '../assets/index-hero.jpg';

const copy = pageCopy.home;
const data = pageData.home;
---

<Layout title={copy.frontmatter.layoutTitle} description={site.description}>
  <section class="home-hero">
    <div class="home-shell">
      <div class="hero-grid mb-16">
        <div class="hero-copy reveal-up">
          <p class="hero-eyebrow">{copy.frontmatter.heroEyebrow}</p>
          <h1>{copy.frontmatter.heroTitle}</h1>
          <p class="hero-lead">{copy.frontmatter.heroLead}</p>
          <div class="hero-cta-row mt-6">
            <a class="btn-primary" href={copy.frontmatter.ctaPrimaryHref}>
              {copy.frontmatter.ctaPrimaryLabel} <i class="ri-arrow-right-up-line"></i>
            </a>
            <a class="btn-secondary" href={copy.frontmatter.ctaSecondaryHref}>
              {copy.frontmatter.ctaSecondaryLabel} <i class="ri-arrow-right-line"></i>
            </a>
          </div>
        </div>

        <aside class="hero-media-frame reveal-scale" style="transition-delay: 200ms;" aria-label="Laboratory Facility">
          <Image
            src={indexHero}
            alt="BioChroma laboratory testing equipment"
            loading="eager"
            class="h-full w-full rounded-2xl object-cover"
          />
          <div class="hero-media-caption">
            <p>{copy.frontmatter.heroMediaTitle}</p>
            <span>{copy.frontmatter.heroMediaText}</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {copy.Content && (
    <section class="home-section border-t border-white/5 bg-slate-900/20">
      <div class="home-shell">
        <div class="prose prose-invert prose-emerald mx-auto max-w-4xl text-center text-lg leading-relaxed text-slate-300 reveal-up">
          <copy.Content />
        </div>
      </div>
    </section>
  )}

  <section class="home-section border-t border-white/5">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.frontmatter.routesTitle}</p>
        <h2>{copy.frontmatter.routesLead}</h2>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {data.routeCards.map((item, index) => (
          <a
            href={item.href}
            class="group flex h-full flex-col rounded-xl border border-white/10 bg-white/5 p-7 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-400/30 hover:bg-emerald-500/5"
            style={`transition-delay: ${index * 80}ms;`}
          >
            <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-emerald-500/10 text-emerald-400">
              <i class={`${item.icon} text-xl`}></i>
            </span>
            <h3 class="mb-2 text-xl font-bold text-white">{item.title}</h3>
            <p class="flex-grow text-sm leading-relaxed text-slate-300">{item.description}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-300 group-hover:text-emerald-200">
              {item.linkLabel}
              <i class="ri-arrow-right-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/50">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.frontmatter.trustTitle}</p>
        <h2>{copy.frontmatter.trustLead}</h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.trustPoints.map((point, index) => (
          <article class="rounded-xl border border-white/10 bg-white/5 p-6 reveal-up" style={`transition-delay: ${index * 100}ms;`}>
            <h3 class="text-base font-semibold text-white">{point.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{point.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5">
    <div class="home-shell max-w-4xl">
      <div class="section-heading reveal-up">
        <p>{copy.frontmatter.scopeTitle}</p>
        <h2>{copy.frontmatter.scopeLead}</h2>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {data.industries.map((industry, index) => (
          <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200 reveal-scale" style={`transition-delay: ${index * 70}ms;`}>
            {industry}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/50">
    <div class="home-shell">
      <div class="section-heading reveal-up">
        <p>{copy.frontmatter.actionsTitle}</p>
        <h2>{copy.frontmatter.actionsLead}</h2>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
        {data.actionCards.map((action, index) => (
          <a href={action.href} class="rounded-xl border border-white/10 bg-white/5 p-6 transition-colors hover:border-emerald-400/30 hover:bg-emerald-500/5 reveal-up" style={`transition-delay: ${index * 100}ms;`}>
            <h3 class="text-lg font-semibold text-white">{action.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{action.description}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-emerald-300">
              {action.label}
              <i class="ri-arrow-right-up-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5">
    <div class="home-shell reveal-up">
      <CTA
        title={copy.frontmatter.ctaTitle}
        description={copy.frontmatter.ctaDescription}
        primaryLabel={copy.frontmatter.ctaPrimaryLabel}
        primaryHref={copy.frontmatter.ctaPrimaryHref}
        secondaryLabel={copy.frontmatter.ctaSecondaryLabel}
        secondaryHref={copy.frontmatter.ctaSecondaryHref}
      />
    </div>
  </section>
</Layout>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .reveal-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .reveal-scale {
      opacity: 0;
      transform: scale(0.95);
      transition: opacity 1s cubic-bezier(0.25, 1, 0.5, 1), transform 1s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .reveal-up.active,
    .reveal-scale.active {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -50px 0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries, observerRef) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observerRef.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const elementsToReveal = document.querySelectorAll('.reveal-up, .reveal-scale');
    elementsToReveal.forEach((el) => observer.observe(el));
  });
</script>
