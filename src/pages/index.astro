---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { getPageContent, getSiteData } from '../content/queries';

import indexHero from '../assets/index-hero.jpg';

const { copy, data, Content } = await getPageContent('home');
const site = await getSiteData();
---

<Layout title={copy.layoutTitle} description={site.description}>
  <section class="home-hero">
    <div class="home-shell">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="hero-eyebrow">{copy.heroEyebrow}</p>
          <h1>{copy.heroTitle}</h1>
          <p class="hero-lead">{copy.heroLead}</p>
          <div class="hero-cta-row mt-6">
            <a class="btn-primary" href={copy.ctaPrimaryHref}>
              {copy.ctaPrimaryLabel} <i class="ri-arrow-right-up-line"></i>
            </a>
            <a class="btn-secondary" href={copy.ctaSecondaryHref}>
              {copy.ctaSecondaryLabel} <i class="ri-arrow-right-line"></i>
            </a>
          </div>
        </div>

        <aside class="hero-media-frame" aria-label="Laboratory Facility">
          <Image
            src={indexHero}
            alt="BioChroma laboratory testing equipment"
            loading="eager"
            class="h-full w-full rounded-2xl object-cover"
          />
          <div class="hero-media-caption">
            <p>{copy.heroMediaTitle}</p>
            <span>{copy.heroMediaText}</span>
          </div>
        </aside>
      </div>
    </div>
  </section>

  {Content && (
    <section class="home-section section-band section-band-bridge">
      <div class="home-shell">
        <div class="prose prose-invert prose-emerald mx-auto max-w-4xl text-center text-lg leading-relaxed text-slate-300 reveal-up bridge-copy">
          <Content />
        </div>
      </div>
    </section>
  )}

  <section class="home-section section-band section-band-routes">
    <div class="home-shell">
      <div class="section-heading">
        <p>{copy.routesTitle}</p>
        <h2>{copy.routesLead}</h2>
      </div>

      <div class="pathway-grid mt-10">
        {data.routeCards.map((item, index) => (
          <a
            href={item.href}
            class:list={[
              'home-card pathway-card group',
              index === 3 && 'pathway-card-left',
              index === 4 && 'pathway-card-right'
            ]}
          >
            <span class="pathway-icon mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg text-emerald-300">
              <i class={`${item.icon} text-xl`}></i>
            </span>
            <h3 class="mb-2 text-xl font-bold text-white">{item.title}</h3>
            <p class="flex-grow text-sm leading-relaxed text-slate-300">{item.description}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-300 transition-colors group-hover:text-emerald-200">
              {item.linkLabel}
              <i class="ri-arrow-right-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section section-band section-band-soft">
    <div class="home-shell">
      <div class="section-heading">
        <p>{copy.trustTitle}</p>
        <h2>{copy.trustLead}</h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-3">
        {data.trustPoints.map((point) => (
          <article class="home-card">
            <h3 class="text-base font-semibold text-white">{point.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">{point.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section section-band">
    <div class="home-shell max-w-4xl">
      <div class="section-heading">
        <p>{copy.scopeTitle}</p>
        <h2>{copy.scopeLead}</h2>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {data.industries.map((industry) => (
          <span class="category-pill">
            {industry}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section section-band section-band-soft">
    <div class="home-shell">
      <div class="section-heading">
        <p>{copy.actionsTitle}</p>
        <h2>{copy.actionsLead}</h2>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
        {data.actionCards.map((action) => (
          <a href={action.href} class="home-card">
            <h3 class="text-lg font-semibold text-white">{action.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{action.description}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-emerald-300">
              {action.label}
              <i class="ri-arrow-right-up-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section section-band">
    <div class="home-shell">
      <CTA
        title={copy.ctaTitle}
        description={copy.ctaDescription}
        primaryLabel={copy.ctaPrimaryLabel}
        primaryHref={copy.ctaPrimaryHref}
        secondaryLabel={copy.ctaSecondaryLabel}
        secondaryHref={copy.ctaSecondaryHref}
      />
    </div>
  </section>
</Layout>

