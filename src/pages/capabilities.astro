---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
import { getPageContent } from '../content/queries';

import capabilitiesHero from '../assets/capabilities-hero.jpg';

const { copy, data, Content } = await getPageContent('capabilities');
---

<Layout
  title={copy.layoutTitle}
  description={copy.layoutDescription}
>
  <section class="home-hero">
    <div class="home-shell">
      <nav class="breadcrumb reveal-up" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">&gt;</span>
        <span class="text-emerald-400 opacity-80">Testing Services</span>
      </nav>

      <div class="hero-grid mb-16">
        <div class="hero-copy reveal-up" style="transition-delay: 100ms;">
          <p class="hero-eyebrow">{copy.heroEyebrow}</p>
          <h1>{copy.heroTitle}</h1>
          <p class="hero-lead">{copy.heroLead}</p>
        </div>

        <div class="hero-media-frame reveal-scale" style="transition-delay: 200ms;">
          <Image
            src={capabilitiesHero}
            alt="BioChroma Labs testing operations"
            loading="eager"
            class="w-full h-full object-cover rounded-2xl"
          />
          <div class="hero-media-caption">
            <p>{copy.heroMediaTitle}</p>
            <span>{copy.heroMediaText}</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {data.serviceLines.map((item, index) => (
          <a
            href={`#${item.id}`}
            class="group bg-white/5 border border-white/10 p-6 rounded-xl hover:bg-emerald-500/5 hover:border-emerald-400/30 transition-all duration-300 reveal-up"
            style={`transition-delay: ${(index * 100) + 300}ms;`}
          >
            <div class="flex items-center gap-4 mb-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-emerald-500/10 text-emerald-400 text-lg">
                <i class={item.icon}></i>
              </span>
              <h2 class="text-white font-bold text-lg group-hover:text-emerald-400 transition-colors">{item.title}</h2>
            </div>
            <p class="text-slate-300 text-sm mb-2">{item.subtitle}</p>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{item.description}</p>
            <span class="text-emerald-400 text-sm font-semibold flex items-center gap-1 opacity-80 group-hover:opacity-100 group-hover:translate-x-1 transition-all">
              View details <i class="ri-arrow-down-line"></i>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {Content && (
    <section class="home-section border-t border-white/5 bg-slate-900/20">
      <div class="home-shell">
        <div class="prose prose-invert prose-emerald max-w-4xl mx-auto text-center text-lg leading-relaxed text-slate-300 reveal-up">
          <Content />
        </div>
      </div>
    </section>
  )}

  <section class="home-section border-t border-white/5 bg-slate-900/40">
    <div class="home-shell">
      <div class="max-w-4xl mx-auto text-center reveal-up">
        <p class="uppercase tracking-widest text-emerald-400 font-bold text-sm mb-4">Orientation</p>
        <h2 class="text-4xl font-bold text-white mb-6">{data.orientation.title}</h2>
        <p class="text-slate-300 text-lg leading-relaxed mb-8">{data.orientation.description}</p>
        <ul class="grid grid-cols-1 md:grid-cols-3 gap-4 text-left">
          {data.orientation.points.map((point) => (
            <li class="bg-white/5 border border-white/10 rounded-xl p-5 text-slate-300 text-sm leading-relaxed">
              <i class="ri-check-line text-emerald-400 mr-2"></i>{point}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="home-section bg-slate-900/60 border-t border-white/5">
    <div class="home-shell">
      <div class="section-heading text-center max-w-3xl mx-auto mb-16 reveal-up">
        <p class="uppercase tracking-widest text-emerald-400 font-bold text-sm mb-4">{copy.overviewEyebrow}</p>
        <h2 class="text-4xl font-bold text-white">{copy.overviewTitle}</h2>
        <div class="h-1 w-20 bg-emerald-500 mx-auto mt-6"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {data.serviceLines.map((line, index) => (
          <article id={line.id} class="scroll-mt-32 bg-white/5 border border-white/10 rounded-2xl p-8 reveal-up" style={`transition-delay: ${index * 150}ms;`}>
            <div class="flex items-center gap-3 mb-5">
              <span class="w-10 h-10 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-xl">
                <i class={line.icon}></i>
              </span>
              <h3 class="text-2xl font-bold text-white">{line.title}</h3>
            </div>
            <p class="text-emerald-400 text-sm uppercase tracking-wider font-semibold mb-3">{line.subtitle}</p>
            <p class="text-slate-300 leading-relaxed mb-5">{line.description}</p>
            <ul class="space-y-3">
              {line.services.map((service) => (
                <li class="text-slate-300 text-sm flex items-start gap-3">
                  <i class="ri-arrow-right-s-line text-emerald-400 mt-0.5"></i>
                  <span>{service}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/10 bg-slate-950/50">
    <div class="home-shell">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <div class="reveal-up">
          <p class="uppercase tracking-widest text-emerald-400 font-bold text-sm mb-4">{copy.customerFitEyebrow}</p>
          <h2 class="text-3xl font-bold text-white mb-5">{copy.customerFitTitle}</h2>
          <ul class="space-y-3">
            {data.customerFit.segments.map((segment) => (
              <li class="bg-white/5 border border-white/10 rounded-xl p-4 text-slate-300 text-sm flex gap-3">
                <i class="ri-user-voice-line text-emerald-400 mt-0.5"></i>
                <span>{segment}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-emerald-500/5 border border-emerald-400/20 rounded-2xl p-8 reveal-up" style="transition-delay: 150ms;">
          <p class="uppercase tracking-widest text-emerald-400 font-bold text-sm mb-4">{copy.relatedPathwayEyebrow}</p>
          <h3 class="text-2xl font-bold text-white mb-4">{data.relatedPathway.title}</h3>
          <p class="text-slate-300 leading-relaxed mb-6">{data.relatedPathway.description}</p>
          <a href={data.relatedPathway.href} class="inline-flex items-center gap-2 text-emerald-400 font-semibold hover:gap-3 transition-all">
            {data.relatedPathway.label}
            <i class="ri-arrow-right-line"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section instrument-registry-section bg-slate-950 border-t border-white/10">
    <div class="home-shell">
      <div class="section-heading mb-12 reveal-up">
        <p class="text-emerald-400 uppercase tracking-widest font-bold text-sm">{copy.registryEyebrow}</p>
        <h2 class="text-white">{copy.registryTitle}</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {data.instrumentRegistry.map((item, index) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-8 hover:bg-emerald-500/5 transition-colors reveal-up" style={`transition-delay: ${index * 150}ms;`}>
            <h4 class="text-emerald-400 text-sm font-bold uppercase tracking-widest border-b border-emerald-400/20 pb-4 mb-6">
              {item.category}
            </h4>
            <ul class="flex flex-col gap-4">
              {item.tools.map((tool) => (
                <li class="text-slate-300 text-sm flex items-start gap-3">
                  <i class="ri-flask-fill text-emerald-400/40 text-sm mt-0.5"></i>
                  {tool}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section border-t border-white/5 bg-slate-900/20">
    <div class="home-shell">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {data.serviceAssurance.map((item, index) => (
          <div class="bg-white/5 border border-white/10 rounded-xl p-6 reveal-up" style={`transition-delay: ${index * 100}ms;`}>
            <div class="w-10 h-10 rounded-lg bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-lg mb-4">
              <i class={item.icon}></i>
            </div>
            <h3 class="text-white font-semibold mb-2">{item.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="home-shell reveal-up">
      <CTA
        title={copy.ctaTitle}
        description={copy.ctaDescription}
        primaryLabel={copy.ctaPrimaryLabel}
        primaryHref={copy.ctaPrimaryHref}
        secondaryLabel={copy.ctaSecondaryLabel}
        secondaryHref={copy.ctaSecondaryHref}
      />
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { font-size: 0.875rem; margin-bottom: 2rem; display: flex; gap: 0.5rem; }
  .breadcrumb a { color: rgba(255, 255, 255, 0.6); text-decoration: none; transition: 0.2s; }
  .breadcrumb a:hover { color: var(--color-primary); }
</style>
